# Optional: enables Gemini chat assistant
VITE_GEMINI_API_KEY=

# Optional: enables Supabase-backed auth/RAG features
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Backward-compatible alias (if your setup exposes "publishable key")
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional: EidKit SSO — login with electronic ID (CEI / NFC)
# Register at https://dashboard.eidkit.ro/ and set redirect URI to:
#   http://localhost:8080/auth/eidkit/callback  (or your deployed origin)
VITE_EIDKIT_CLIENT_ID=
VITE_EIDKIT_CLIENT_SECRET=
